# ── Server ──
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://gateway:changeme@localhost:5432/llm_gateway
DB_POOL_MIN=5
DB_POOL_MAX=20

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# ── Rate Limiting ──
RATE_LIMIT_BUCKET_MAX=100000
RATE_LIMIT_WINDOW_SECONDS=18000

# ── Cache ──
CACHE_TTL_SECONDS=600
CACHE_MAX_TEMPERATURE=0.3

# ── Circuit Breaker ──
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RESET_TTL_SECONDS=300

# ── Providers ──
ENABLED_PROVIDERS=["groq","openrouter","nvidia"]
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxx
PROVIDER_TIMEOUT_DEFAULT=30.0
GROQ_TIMEOUT=15.0
OPENROUTER_TIMEOUT=30.0
NVIDIA_TIMEOUT=45.0

# ── Guardrails ──
MAX_PAYLOAD_BYTES=1048576
MAX_MESSAGES=50
MAX_SINGLE_MESSAGE_CHARS=50000
MAX_MAX_TOKENS=8192

# ── Supabase (for dashboard auth) ──
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx

DASHBOARD_URL: str = http://localhost:5173